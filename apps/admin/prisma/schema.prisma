// Minimal, standalone schema for the admin app - points at the same
// database as apps/web but only models what this app reads/writes
// (User, Project, ProjectUsers). Field names/types must match the real
// columns in apps/web/prisma/schema exactly; this app never runs migrations
// (apps/web owns the schema/migrations).

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String    @id
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())

  projects ProjectUsers[]
}

model Project {
  id   String @id
  name String
  slug String @unique

  plan       String @default("free")
  planTier   Int    @default(1)
  usageLimit Int    @default(1000)
  linksLimit Int    @default(25)
  domainsLimit Int  @default(3)
  tagsLimit  Int    @default(5)

  totalLinks  Int @default(0)
  totalClicks Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users ProjectUsers[]

  @@index(slug)
}

enum WorkspaceRole {
  owner
  member
}

// Owned entirely by this app - apps/web has no knowledge of this table.
model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  createdAt    DateTime @default(now())
}

model ProjectUsers {
  id        String        @id @default(cuid())
  role      WorkspaceRole @default(member)
  userId    String
  projectId String
  createdAt DateTime      @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index(projectId)
}
