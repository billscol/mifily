# Plantilla de variables de entorno para producción (mifily.com / mifi.uno).
# Copiar como `.env` junto a docker-compose.prod.yml en el servidor
# (/www/wwwroot/mifily/) y rellenar con valores reales. NO commitear ese
# archivo real: docker-compose ya lo lee vía `env_file: .env`.

###############################
###### CORE ######
###############################

# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://app.mifily.com

# Secreto compartido para los cron jobs internos (ver deploy/crontab.template)
CRON_SECRET=

# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=

###############################
###### BASE DE DATOS (MariaDB propio del VPS) ######
###############################

# Creada vía aaPanel -> Bases de datos -> Añadir. El contenedor alcanza el
# host por "host.docker.internal" (ver extra_hosts en docker-compose.prod.yml).
DATABASE_URL="mysql://USUARIO:PASSWORD@host.docker.internal:3306/mifily_dub"

###############################
###### UPSTASH (Redis + QStash) ######
###############################

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

QSTASH_URL=
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

###############################
###### TINYBIRD (analytics) ######
###############################

TINYBIRD_API_KEY=
TINYBIRD_API_URL=https://api.tinybird.co

###############################
###### GITHUB OAUTH (login) ######
###############################

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

###############################
###### RESEND (magic link / emails) ######
###############################

RESEND_API_KEY=

###############################
###### STORAGE (MinIO propio del VPS, vía cdn.mifily.com) ######
###############################

MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

STORAGE_ENDPOINT=https://cdn.mifily.com
STORAGE_BASE_URL=https://cdn.mifily.com/mifily-public
STORAGE_PUBLIC_BUCKET=mifily-public
STORAGE_PRIVATE_BUCKET=mifily-private
# Mismos valores que MINIO_ROOT_USER / MINIO_ROOT_PASSWORD
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=

###############################
###### ADMIN PANEL (admin.mifily.com) ######
###############################

# Password para entrar al panel admin (gestión de planes/usuarios)
ADMIN_PASSWORD=
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
# Compartido entre el panel admin y la app principal (mismo valor en ambos,
# ya que ambos leen este mismo .env) - protege los endpoints
# /api/admin-internal/* de la app principal.
ADMIN_INTERNAL_SECRET=
